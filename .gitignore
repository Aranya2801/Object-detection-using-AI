# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# ── Virtual environments ─────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── YOLO model weights (large binary files) ──────────────────────
*.pt
*.pth
*.weights
*.onnx
*.engine
*.tflite
*.mlmodel
*.pb
!models/.gitkeep   # keep the folder

# ── Data & outputs ───────────────────────────────────────────────
data/outputs/*
!data/outputs/.gitkeep
data/samples/*
!data/samples/.gitkeep
runs/

# ── Jupyter ──────────────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb_checkpoints/

# ── IDEs ─────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Testing & coverage ───────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ── Docker ───────────────────────────────────────────────────────
.dockerignore

# ── Logs ─────────────────────────────────────────────────────────
*.log
logs/

# ── Secrets ──────────────────────────────────────────────────────
.env
*.key
*.secret
